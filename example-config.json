{
  "$schema": "https://docs.openclaw.ai/schema/openclaw.json",
  "_comment": "Example OpenClaw config with Claude Code ACP forwarding. Replace <PLACEHOLDERS> with your values.",

  "acp": {
    "enabled": true,
    "backend": "acpx",
    "defaultAgent": "claude",
    "allowedAgents": ["claude", "codex"]
  },

  "plugins": {
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "permissionMode": "approve-all"
        }
      }
    }
  },

  "agents": {
    "list": [
      {
        "id": "main"
      },
      {
        "id": "claude-acp",
        "runtime": {
          "type": "acp",
          "acp": {
            "agent": "claude",
            "backend": "acpx",
            "mode": "persistent"
          }
        }
      }
    ]
  },

  "bindings": [
    {
      "_comment": "Route this Discord DM through Claude Code ACP",
      "type": "acp",
      "agentId": "claude-acp",
      "match": {
        "channel": "discord",
        "accountId": "default",
        "peer": {
          "kind": "dm",
          "id": "<YOUR_DM_CHANNEL_ID>"
        }
      },
      "acp": {
        "mode": "persistent"
      }
    },
    {
      "_comment": "Default route for everything else",
      "type": "route",
      "agentId": "main",
      "match": {
        "channel": "discord",
        "accountId": "default"
      }
    }
  ]
}
